---
// Museum-placard layout: mono date column on the left, title/narrative on the right.
// Asymmetric grid; on mobile collapses to single column with date as a small eyebrow.
interface Props {
  index: string;       // e.g. "01"
  dates: string;       // mono caps line
  tag?: string;        // small accent label e.g. "COMMERCIAL"
  title: string;       // display serif
  stack: string[];
  pull?: string;       // optional pull-quote/stat
  pullLabel?: string;  // optional small label for the stat
}
const { index, dates, tag, title, stack, pull, pullLabel } = Astro.props;
---

<article class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-5 md:gap-x-10 py-12 border-t border-ink-700">
  <!-- Left rail: index + dates + tag -->
  <aside class="md:col-span-3 lg:col-span-3 flex flex-col gap-3 md:sticky md:top-10 md:self-start">
    <div class="flex items-baseline gap-3">
      <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">№ {index}</span>
      {tag && (
        <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">
          {tag}
        </span>
      )}
    </div>
    <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300 leading-relaxed">
      {dates}
    </p>
  </aside>

  <!-- Right content -->
  <div class="md:col-span-9 lg:col-span-9 flex flex-col gap-5">
    <h2
      class="font-display font-light text-fluid-2xl text-ink-50 leading-[1.05] tracking-tightest max-w-[28ch]"
    >
      <slot name="title">{title}</slot>
    </h2>

    <div class="max-w-readable text-fluid-base text-ink-100 leading-relaxed">
      <slot />
    </div>

    {pull && (
      <figure class="mt-2 mb-1 max-w-readable border-l border-accent pl-5">
        <blockquote class="font-display font-light italic text-fluid-lg text-ink-50 leading-tight">
          {pull}
        </blockquote>
        {pullLabel && (
          <figcaption class="mt-2 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">
            — {pullLabel}
          </figcaption>
        )}
      </figure>
    )}

    <div class="pt-2">
      <p class="font-mono text-mono-xs uppercase tracking-[0.16em] text-ink-300 leading-relaxed">
        {stack.map((s, i) => (
          <>
            <span>{s}</span>
            {i < stack.length - 1 && <span class="text-ink-500 mx-2">·</span>}
          </>
        ))}
      </p>
    </div>
  </div>
</article>
