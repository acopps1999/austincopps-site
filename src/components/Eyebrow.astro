---
interface Props {
  accent?: boolean;
  delay?: number;
}
const { accent = false, delay = 0 } = Astro.props;
---

<p
  class:list={[
    'reveal font-mono text-mono-xs uppercase tracking-[0.18em]',
    accent ? 'text-coral' : 'text-cream-500',
  ]}
  style={delay ? `transition-delay: ${delay}ms;` : undefined}
>
  <slot />
</p>
