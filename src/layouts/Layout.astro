---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  pageKey?: 'about' | 'work' | 'projects' | 'uses';
}

const {
  title = 'Austin Copps — Generative-AI builder',
  description = 'Austin Copps — generative-AI builder. Lead AI Analyst at Worlds, solo-shipper of commercial AI applications.',
  pageKey = 'about',
} = Astro.props;

const nav = [
  { href: '/', key: 'about', label: 'about' },
  { href: '/work', key: 'work', label: 'work' },
  { href: '/projects', key: 'projects', label: 'projects' },
  { href: '/uses', key: 'uses', label: 'uses' },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#fdf9ee" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://austincopps.com${Astro.url.pathname}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={`https://austincopps.com${Astro.url.pathname}`} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Geist:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <title>{title}</title>
  </head>
  <body class="min-h-dvh antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-cream-50 focus:text-cream-900 focus:px-3 focus:py-2 focus:border focus:border-coral"
    >
      Skip to content
    </a>

    <header class="w-full">
      <div
        class="mx-auto max-w-[1240px] px-6 md:px-10 pt-6 md:pt-8 pb-4 flex items-baseline justify-between"
      >
        <a
          href="/"
          class="font-mono text-mono-sm uppercase tracking-[0.18em] text-cream-800 hover:text-coral transition-colors"
        >
          Austin&nbsp;Copps
          <span class="text-cream-400 ml-2">/&nbsp;portfolio</span>
        </a>

        <nav aria-label="Primary" class="hidden md:block">
          <ul class="flex gap-7 items-baseline">
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={item.key === pageKey ? 'page' : undefined}
                    class:list={[
                      'font-mono text-mono-sm uppercase tracking-[0.18em] transition-colors',
                      item.key === pageKey
                        ? 'text-coral'
                        : 'text-cream-500 hover:text-cream-900',
                    ]}
                  >
                    {item.key === pageKey && (
                      <span class="text-coral mr-1" aria-hidden="true">
                        ●
                      </span>
                    )}
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <details class="md:hidden relative">
          <summary
            class="list-none cursor-pointer font-mono text-mono-sm uppercase tracking-[0.18em] text-cream-700"
            aria-label="Toggle menu"
          >
            menu
          </summary>
          <ul
            class="absolute right-0 top-full mt-3 min-w-[180px] border border-cream-300 bg-cream-50 p-4 flex flex-col gap-3 z-20"
          >
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={item.key === pageKey ? 'page' : undefined}
                    class:list={[
                      'font-mono text-mono-sm uppercase tracking-[0.18em] block',
                      item.key === pageKey
                        ? 'text-coral'
                        : 'text-cream-700 hover:text-coral',
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </details>
      </div>
      <div class="mx-auto max-w-[1240px] px-6 md:px-10">
        <div class="hairline"></div>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-[1240px] px-6 md:px-10 py-12 md:py-20">
      <slot />
    </main>

    <footer class="w-full mt-8">
      <div class="mx-auto max-w-[1240px] px-6 md:px-10">
        <div class="hairline"></div>
      </div>
      <div
        class="mx-auto max-w-[1240px] px-6 md:px-10 py-10 flex flex-col md:flex-row gap-4 md:gap-8 md:items-baseline md:justify-between"
      >
        <p class="font-mono text-mono-xs uppercase tracking-[0.16em] text-cream-400">
          © 2026 Austin Copps
        </p>
        <ul class="flex flex-wrap gap-5 font-mono text-mono-xs uppercase tracking-[0.16em]">
          <li><a class="link text-cream-700" href="mailto:austin@austincopps.com">email</a></li>
          <li>
            <a class="link text-cream-700" href="https://github.com/acopps1999" target="_blank" rel="noopener"
              >github</a
            >
          </li>
          <li>
            <a
              class="link text-cream-700"
              href="https://linkedin.com/in/austin-copps-06332621b"
              target="_blank"
              rel="noopener">linkedin</a
            >
          </li>
        </ul>
      </div>
    </footer>

    <script is:inline>
      // Fade-up reveals on scroll; respects prefers-reduced-motion.
      // Reveals are visible by default; we only opt into the animation
      // when JS is alive *and* the user hasn't asked for reduced motion.
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) return;
        document.documentElement.classList.add('js-reveal');
        const targets = Array.from(document.querySelectorAll('.reveal'));
        // Immediately reveal anything already on screen so we never flash blank.
        const vh = window.innerHeight;
        targets.forEach((el) => {
          if (el.getBoundingClientRect().top < vh * 0.95) {
            el.classList.add('is-visible');
          }
        });
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 }
        );
        targets.forEach((el) => {
          if (!el.classList.contains('is-visible')) io.observe(el);
        });
      })();
    </script>
  </body>
</html>
