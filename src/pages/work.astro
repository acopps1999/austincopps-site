---
import Layout from '../layouts/Layout.astro';

const roles = [
  {
    index: '01',
    dates: 'JUN 2025 — PRESENT',
    company: 'Worlds',
    title: 'Lead AI Analyst, Forward Deployed Engineering',
    location: 'Promoted from Associate Solutions Architect',
    narrative:
      "Promoted into the role; I help own the analysis, monitoring, and iteration of every production and pilot AI solution in the company's portfolio. Designed and built an internal platform — end to end with agentic AI development — that's become the analyst team's primary working surface, deployed on Azure. Embed directly with customers as part of the FDE team — translating SOPs into AI-readable data, debugging drift in the field, and shipping production fixes alongside engineering in the same engagement.",
    stack: ['Azure', 'Agentic AI', 'FastAPI', 'Python', 'UI / UX'],
  },
  {
    index: '02',
    dates: 'JUL 2023 — JUN 2025',
    company: 'Worlds',
    title: 'Associate Solutions Architect',
    location: 'Worlds.io · Venture-funded industrial-AI platform',
    narrative:
      "Reported to the Director of Solution Architecture. Designed, planned, and implemented Worlds AI deployments for industrial customers. Translated customer problems into AI training plans — designing datasets, training computer-vision models, and validating they augmented operators rather than replaced them. Drove SOP-side conversations with clients that materially improved downstream model performance.",
    stack: ['Computer vision', 'Solution architecture', 'Customer discovery'],
  },
  {
    index: '03',
    dates: 'JUN 2022 — AUG 2022',
    company: 'LossExpress',
    title: 'Data Analyst Intern',
    location: 'lossexpress.com · Total-loss claims automation',
    narrative:
      "Worked directly with the CFO to introduce automation into call-center workflows. Built a low-code Airtable system to formalize routines and surface bottlenecks back to leadership. Contributed to the operational gains that helped LossExpress service 80%+ of US total-loss claims at the time.",
    stack: ['Airtable', 'Process automation', 'Analytics'],
  },
  {
    index: '04',
    dates: 'MAY 2021 — AUG 2021',
    company: 'Worlds',
    title: 'Engineering Intern',
    location: 'First hands-on exposure to the AI lifecycle',
    narrative:
      "Trained computer-vision models inside digital twins to detect objects, people, and operational events — first hands-on exposure to model drift, labeling quality, and the real-world AI lifecycle.",
    stack: ['Computer vision', 'Digital twins', 'Data labeling'],
  },
];

const credentials = [
  { label: 'Texas Tech University', meta: 'B.A., Business Management · Strategic Entrepreneurship', date: 'Dec 2022' },
  { label: 'Worlds Trainer Certification', meta: 'Web-based AI training tool focused on computer vision', date: 'Mar 2023' },
  { label: 'Worlds Builder Certification', meta: 'Web-based digital-twin environment builder', date: 'Mar 2023' },
  { label: 'IBM Data Science Introduction', meta: 'Coursera', date: 'Feb 2023' },
];
---

<Layout
  pageKey="work"
  title="Work — Austin Copps"
  description="Austin Copps' work history — Lead AI Analyst at Worlds, prior solution-architecture and analytics roles."
>
  <!-- Page header -->
  <header class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 pb-16 md:pb-20">
    <div class="md:col-span-3">
      <p class="reveal font-mono text-mono-xs uppercase tracking-[0.2em] text-coral">Work</p>
    </div>
    <div class="md:col-span-9">
      <h1 class="reveal font-display font-light text-fluid-3xl tracking-tightest text-cream-900 leading-[0.95]">
        Where I've been.
      </h1>
      <p class="reveal mt-6 max-w-readable text-fluid-lg text-cream-800 leading-relaxed" style="transition-delay: 120ms;">
        A short list of places I've been lucky enough to do interesting work.
      </p>
    </div>
  </header>

  <!-- Roles -->
  <section>
    {
      roles.map((role) => (
        <article class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-5 md:gap-x-10 py-12 border-t border-cream-200">
          <aside class="md:col-span-3 flex flex-col gap-3 md:sticky md:top-10 md:self-start">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-coral">№ {role.index}</span>
            </div>
            <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-cream-500 leading-relaxed">
              {role.dates}
            </p>
          </aside>

          <div class="md:col-span-9 flex flex-col gap-5">
            <header>
              <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-cream-500">{role.company}</p>
              <h2 class="mt-2 font-display font-light text-fluid-2xl text-cream-900 leading-[1.05] tracking-tightest max-w-[28ch]">
                {role.title}
              </h2>
              <p class="mt-3 font-mono text-mono-xs uppercase tracking-[0.16em] text-cream-400">
                {role.location}
              </p>
            </header>

            <p class="max-w-readable text-fluid-base text-cream-800 leading-relaxed">{role.narrative}</p>

            <p class="pt-2 font-mono text-mono-xs uppercase tracking-[0.16em] text-cream-500 leading-relaxed">
              {role.stack.map((s, i) => (
                <>
                  <span>{s}</span>
                  {i < role.stack.length - 1 && <span class="text-cream-300 mx-2">·</span>}
                </>
              ))}
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <!-- Education + Certs -->
  <section class="mt-20 md:mt-28 border-t border-cream-200 pt-16">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-3">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-coral">Addendum</p>
        <h2 class="reveal mt-3 font-display font-light text-fluid-xl tracking-tightest text-cream-900">
          Education<br />& certs.
        </h2>
      </div>
      <ul class="md:col-span-9 flex flex-col">
        {
          credentials.map((c, i) => (
            <li
              class="reveal grid grid-cols-12 gap-3 md:gap-6 items-baseline border-t border-cream-200 py-5"
              style={`transition-delay: ${i * 60}ms;`}
            >
              <span class="col-span-12 sm:col-span-3 md:col-span-2 font-mono text-mono-xs uppercase tracking-[0.18em] text-cream-500">
                {c.date}
              </span>
              <p class="col-span-12 sm:col-span-9 md:col-span-10 text-fluid-base text-cream-800 leading-relaxed">
                <span class="text-cream-900">{c.label}</span>
                <span class="text-cream-400"> — {c.meta}</span>
              </p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Layout>
