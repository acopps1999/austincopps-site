---
import Layout from '../layouts/Layout.astro';

const demos = [
  {
    index: '01',
    status: 'In design',
    title: 'Streaming chat',
    sub: 'A minimal interface that talks to a small, well-behaved agent.',
    body: "No fluff. A text field, a system prompt I'm proud of, streaming tokens, and a visible preparing state so you can feel the model thinking. Aimed at being the 'hello world' that doesn't lie about latency.",
    cta: 'Coming soon',
  },
  {
    index: '02',
    status: 'In development',
    title: 'Tool-calling agent',
    sub: 'A tiny task agent that picks tools and shows its trace.',
    body: 'Ask it to do something small — fetch the weather, classify a snippet, summarize a URL — and watch it choose, call, and explain. The trace is the demo: visible reasoning, visible tool selection, visible recovery on errors.',
    cta: 'Coming soon',
  },
  {
    index: '03',
    status: 'Queued',
    title: 'RAG over my projects',
    sub: 'Ask questions about anything in my project repos.',
    body: '"How does Chirp handle weather failover?" "What does Switchboard do when Sentry pings?" An embedding index over my own codebases and notes, plus a strict citation policy so every answer points to the exact file and line.',
    cta: 'Coming soon',
  },
];
---

<Layout
  pageKey="playground"
  title="Playground — Austin Copps"
  description="A space for live demos of the things Austin Copps builds."
>
  <header class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 pb-16 md:pb-20">
    <div class="md:col-span-3">
      <p class="reveal font-mono text-mono-xs uppercase tracking-[0.2em] text-coral">Playground</p>
    </div>
    <div class="md:col-span-9">
      <h1 class="reveal font-display font-light text-fluid-3xl tracking-tightest text-cream-900 leading-[0.95]">
        A space for the things<br /><span class="italic">I'm building live.</span>
      </h1>
      <p class="reveal mt-6 max-w-readable text-fluid-lg text-cream-800 leading-relaxed" style="transition-delay: 120ms;">
        Demos are arriving here as they harden. The shape is intentional, the schedule is real — these are the next three.
      </p>
    </div>
  </header>

  <section class="grid grid-cols-1 md:grid-cols-12 gap-y-6 md:gap-x-10">
    {
      demos.map((d, i) => (
        <article
          class="reveal md:col-span-12 grid grid-cols-1 md:grid-cols-12 gap-y-4 md:gap-x-10 border-t border-cream-200 py-12 group relative"
          style={`transition-delay: ${i * 80}ms;`}
        >
          <aside class="md:col-span-3 flex flex-col gap-3 md:sticky md:top-10 md:self-start">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-coral">№ {d.index}</span>
            </div>
            <span class="inline-flex items-center gap-2 font-mono text-mono-xs uppercase tracking-[0.18em] text-cream-500">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-cream-400" aria-hidden="true"></span>
              {d.status}
            </span>
          </aside>

          <div class="md:col-span-9 flex flex-col gap-4">
            <h2 class="font-display font-light text-fluid-2xl text-cream-900 leading-[1.05] tracking-tightest max-w-[28ch]">
              {d.title}
            </h2>
            <p class="max-w-readable text-fluid-lg text-cream-800 leading-relaxed">{d.sub}</p>
            <p class="max-w-readable text-fluid-base text-cream-700 leading-relaxed">{d.body}</p>
            <p class="mt-3 font-mono text-mono-xs uppercase tracking-[0.18em] text-cream-400">
              {d.cta}
              <span class="text-cream-200 mx-2">·</span>
              <a href="mailto:austin@austincopps.com" class="link text-cream-700">
                want a preview? get in touch
              </a>
            </p>
          </div>
        </article>
      ))
    }
  </section>

  <section class="mt-20 md:mt-28 border-t border-cream-200 pt-12">
    <p class="reveal max-w-readable text-fluid-base text-cream-500 leading-relaxed">
      Each demo runs against a small Cloudflare Worker so the site itself stays a static GitHub Pages
      deployment. Bookmark this page if you want to see the seams as they shake out.
    </p>
  </section>
</Layout>
