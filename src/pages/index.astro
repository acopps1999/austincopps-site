---
import Layout from '../layouts/Layout.astro';
---

<Layout
  pageKey="about"
  title="Austin Copps — Generative-AI builder who ships solo"
  description="Lead AI Analyst at Worlds. Builder, fixer, problem-solver. Solo-ships commercial generative-AI applications end to end."
>
  <!-- HERO -->
  <section class="relative pt-6 md:pt-10 pb-20 md:pb-28">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 items-start">
      <!-- Left: signal column -->
      <aside class="md:col-span-3 flex flex-col gap-6 md:pt-3">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.2em] text-accent">
          <span class="inline-block w-1.5 h-1.5 bg-accent rounded-full mr-2 align-middle animate-pulse"></span>
          Available for new work
        </p>
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300 leading-relaxed" style="transition-delay: 80ms;">
          Generative-AI builder<br />Dallas, TX<br />Class of 2022
        </p>
        <div class="reveal hairline max-w-[120px]" style="transition-delay: 160ms;"></div>
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400 leading-relaxed" style="transition-delay: 240ms;">
          File 01<br />Personal index
        </p>
      </aside>

      <!-- Center/right: headline -->
      <div class="md:col-span-9">
        <h1
          class="reveal font-display font-light text-fluid-display text-ink-50 leading-[0.92] tracking-tightest"
          style="transition-delay: 60ms;"
        >
          I build AI<br />
          <span class="italic font-normal">that actually</span><br />
          ships.<span class="text-accent">_</span>
        </h1>

        <div class="reveal mt-10 md:mt-14 max-w-[58ch] text-fluid-lg text-ink-100 leading-relaxed" style="transition-delay: 220ms;">
          <p>
            Lead AI Analyst on a forward-deployed engineering team at
            <a class="link text-ink-50" href="https://worlds.io" target="_blank" rel="noopener">Worlds</a>.
            Outside of that, I ship commercial applications end&nbsp;to&nbsp;end — a contracted
            <span class="text-accent">appellate-court classifier</span> built with a small team, a solo
            <span class="text-accent">recommendation system</span> for a merged periodontics company, and a solo
            <span class="text-accent">camp-safety platform</span> launching on the App Store.
          </p>
        </div>

        <div class="reveal mt-10 flex flex-wrap items-center gap-6 md:gap-8" style="transition-delay: 320ms;">
          <a class="link font-mono text-mono-sm uppercase tracking-[0.16em] text-ink-50" href="/work">
            See work history&nbsp;&nbsp;→
          </a>
          <a class="link font-mono text-mono-sm uppercase tracking-[0.16em] text-ink-50" href="/projects">
            See projects&nbsp;&nbsp;→
          </a>
          <a
            class="link font-mono text-mono-sm uppercase tracking-[0.16em] text-ink-50"
            href="mailto:austin@austincopps.com"
          >
            Reach out&nbsp;&nbsp;→
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section class="py-12 md:py-16 border-y border-ink-700">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 md:gap-x-8">
      <div class="reveal">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Commercial apps shipped</p>
        <p class="mt-2 font-display font-light text-fluid-2xl text-ink-50">03 <span class="text-ink-400">·</span> <span class="text-ink-300 font-mono text-mono-sm align-middle">end&nbsp;to&nbsp;end</span></p>
      </div>
      <div class="reveal" style="transition-delay: 80ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">AI solutions owned</p>
        <p class="mt-2 font-display font-light text-fluid-2xl text-ink-50">Entire <span class="text-ink-300 font-mono text-mono-sm align-middle">production portfolio</span></p>
      </div>
      <div class="reveal" style="transition-delay: 160ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Cases / year at scale</p>
        <p class="mt-2 font-display font-light text-fluid-2xl text-ink-50">~2,000 <span class="text-ink-300 font-mono text-mono-sm align-middle">classified</span></p>
      </div>
      <div class="reveal" style="transition-delay: 240ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Cost cut via agentic redesign</p>
        <p class="mt-2 font-display font-light text-fluid-2xl text-ink-50">~90% <span class="text-ink-300 font-mono text-mono-sm align-middle">per query</span></p>
      </div>
    </div>
  </section>

  <!-- DOSSIER / ABOUT ME -->
  <section class="py-24 md:py-32" id="about">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-y-10 md:gap-x-12 items-start">
      <!-- Portrait + dossier card -->
      <div class="md:col-span-5 lg:col-span-4 md:sticky md:top-12">
        <div class="reveal">
          <p class="font-mono text-mono-xs uppercase tracking-[0.2em] text-accent">Dossier N° 01</p>
          <p class="mt-1 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">
            Filed 2026 · Dallas, TX
          </p>
        </div>

        <figure class="reveal mt-5 relative" style="transition-delay: 80ms;">
          <!-- Photo frame -->
          <div class="relative border border-ink-600 bg-ink-800 p-2.5 shadow-[0_30px_60px_-30px_rgba(0,0,0,0.7)]">
            <!-- corner ticks -->
            <span aria-hidden="true" class="absolute -top-px -left-px w-3 h-3 border-t border-l border-accent"></span>
            <span aria-hidden="true" class="absolute -top-px -right-px w-3 h-3 border-t border-r border-accent"></span>
            <span aria-hidden="true" class="absolute -bottom-px -left-px w-3 h-3 border-b border-l border-accent"></span>
            <span aria-hidden="true" class="absolute -bottom-px -right-px w-3 h-3 border-b border-r border-accent"></span>

            <img
              src="/portrait.jpg"
              alt="Austin Copps, portrait"
              width="1024"
              height="1024"
              loading="lazy"
              decoding="async"
              class="block w-full h-auto select-none portrait-img"
            />
          </div>

          <!-- Caption block beneath -->
          <figcaption class="mt-4 grid grid-cols-12 gap-x-3 gap-y-2 font-mono text-mono-xs uppercase tracking-[0.16em] text-ink-300">
            <span class="col-span-4 text-ink-500">Subject</span>
            <span class="col-span-8 text-ink-100">Austin&nbsp;Copps</span>
            <span class="col-span-4 text-ink-500">Field</span>
            <span class="col-span-8 text-ink-100">Generative&nbsp;AI&nbsp;·&nbsp;Software</span>
            <span class="col-span-4 text-ink-500">Status</span>
            <span class="col-span-8 text-accent">Builds, fixes, solves</span>
            <span class="col-span-4 text-ink-500">Stationed</span>
            <span class="col-span-8 text-ink-100">Dallas, TX</span>
          </figcaption>
        </figure>
      </div>

      <!-- Narrative -->
      <div class="md:col-span-7 lg:col-span-8">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.2em] text-accent">01 — Who I am</p>
        <h2
          class="reveal mt-4 font-display font-light text-fluid-3xl tracking-tightest text-ink-50 leading-[0.96] max-w-[16ch]"
          style="transition-delay: 80ms;"
        >
          A builder<br />
          <span class="italic">in the wide sense</span><br />
          of the word.
        </h2>

        <div class="reveal mt-10 max-w-readable text-fluid-base text-ink-100 leading-relaxed space-y-5" style="transition-delay: 160ms;">
          <p>
            I'm Austin. I write software for a living, but the wiring is older than that. I'm a gearhead and a silicon-head — I build cars and I build computers, and the line between the two has been getting blurrier my entire life. Both are systems. Both reward patience. Both punish hand-waving.
          </p>
          <p>
            Off the keyboard I'm a gamer, a card collector, a deck-builder, and a racquet-and-ball-sports guy — pickleball lately, with tennis and baseball never far away. The thread through all of it is the same one that shows up at work: I want to understand how the thing actually works, and then I want to make it run better than it did when I found it.
          </p>
          <p>
            Above all of that <span class="italic">— above the titles, the stack, the resume —</span> I love building things, fixing things, and solving problems. That's the whole job description, in any room I walk into.
          </p>
        </div>

        <!-- Margin notes -->
        <ul class="reveal mt-12 grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-10 max-w-readable" style="transition-delay: 240ms;">
          <li class="grid grid-cols-12 gap-3 items-baseline border-t border-ink-700 pt-3">
            <span class="col-span-4 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Currently</span>
            <span class="col-span-8 text-fluid-sm text-ink-100">Shipping Chirp to the App Store</span>
          </li>
          <li class="grid grid-cols-12 gap-3 items-baseline border-t border-ink-700 pt-3">
            <span class="col-span-4 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Tinkering with</span>
            <span class="col-span-8 text-fluid-sm text-ink-100">Always-on Claude agents</span>
          </li>
          <li class="grid grid-cols-12 gap-3 items-baseline border-t border-ink-700 pt-3">
            <span class="col-span-4 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">Reading</span>
            <span class="col-span-8 text-fluid-sm text-ink-100">Whatever's open in the tabs</span>
          </li>
          <li class="grid grid-cols-12 gap-3 items-baseline border-t border-ink-700 pt-3">
            <span class="col-span-4 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400">On court</span>
            <span class="col-span-8 text-fluid-sm text-ink-100">Pickleball, way too often</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- HOW I WORK -->
  <section class="py-20 md:py-28 border-t border-ink-700 grid grid-cols-1 md:grid-cols-12 gap-10">
    <div class="md:col-span-4">
      <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">02 — How I work</p>
      <h2 class="reveal mt-4 font-display font-light text-fluid-2xl tracking-tightest text-ink-50">
        End to end.<br /><span class="italic">Often solo.</span>
      </h2>
    </div>
    <div class="md:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-10">
      <div class="reveal">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Discovery</p>
        <p class="mt-3 max-w-readable text-fluid-base text-ink-100 leading-relaxed">
          I sit with the people who'll use the thing. Translate the messy reality into a shape an AI system can actually run on. No throwing it over the wall.
        </p>
      </div>
      <div class="reveal" style="transition-delay: 80ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Architecture</p>
        <p class="mt-3 max-w-readable text-fluid-base text-ink-100 leading-relaxed">
          Pick the right model, the right retrieval, the right tools — and the right humans in the loop. Boring infra. Explainable outputs. Audit trails by default.
        </p>
      </div>
      <div class="reveal" style="transition-delay: 160ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Build & ship</p>
        <p class="mt-3 max-w-readable text-fluid-base text-ink-100 leading-relaxed">
          Frontend, backend, mobile, deploys, CI, observability — handled. I use agentic AI on my own work, so the cycle from idea to deployed feature collapses.
        </p>
      </div>
      <div class="reveal" style="transition-delay: 240ms;">
        <p class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Maintain & iterate</p>
        <p class="mt-3 max-w-readable text-fluid-base text-ink-100 leading-relaxed">
          I keep watching. Drift, edge cases, new feedback. Switchboard — my own internal ops platform — observes my products and tells me what to fix next.
        </p>
      </div>
    </div>
  </section>

  <!-- WORKSHOP / OFF THE CLOCK -->
  <section class="py-20 md:py-28 border-t border-ink-700">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 pb-10">
      <div class="md:col-span-4">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">03 — Workshop</p>
        <h2 class="reveal mt-4 font-display font-light text-fluid-2xl tracking-tightest text-ink-50">
          Off the clock,<br /><span class="italic">still building.</span>
        </h2>
      </div>
      <div class="md:col-span-8">
        <p class="reveal max-w-readable text-fluid-lg text-ink-100 leading-relaxed">
          The things I love outside of work are the same things at heart: a system to understand, a thing to build, a problem to solve. Different uniforms, same job.
        </p>
      </div>
    </div>

    <ul class="flex flex-col">
      <li class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-10 border-t border-ink-700 py-8">
        <div class="md:col-span-3 flex flex-col gap-2">
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">N° 01</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Gearhead</span>
        </div>
        <div class="md:col-span-9">
          <h3 class="font-display font-light text-fluid-xl text-ink-50 leading-tight">Cars</h3>
          <p class="mt-2 max-w-readable text-fluid-base text-ink-200 leading-relaxed">
            I tear down engines for the same reason I read source code — to understand the system. There's nothing quite like the feeling of a thing you built and tuned roaring back to life.
          </p>
        </div>
      </li>
      <li class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-10 border-t border-ink-700 py-8" style="transition-delay: 60ms;">
        <div class="md:col-span-3 flex flex-col gap-2">
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">N° 02</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Silicon-head</span>
        </div>
        <div class="md:col-span-9">
          <h3 class="font-display font-light text-fluid-xl text-ink-50 leading-tight">Computers</h3>
          <p class="mt-2 max-w-readable text-fluid-base text-ink-200 leading-relaxed">
            Custom builds, water loops, BIOS tuning, the works. Hardware is just software you can hold. The two have been the same hobby for me since I was a kid.
          </p>
        </div>
      </li>
      <li class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-10 border-t border-ink-700 py-8" style="transition-delay: 120ms;">
        <div class="md:col-span-3 flex flex-col gap-2">
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">N° 03</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Collector · Deck-builder</span>
        </div>
        <div class="md:col-span-9">
          <h3 class="font-display font-light text-fluid-xl text-ink-50 leading-tight">Cards</h3>
          <p class="mt-2 max-w-readable text-fluid-base text-ink-200 leading-relaxed">
            I collect, I read sleeves like patch notes, and I build decks. Most card games are systems-design problems wearing a different jacket — and the deck is the architecture diagram.
          </p>
        </div>
      </li>
      <li class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-10 border-t border-ink-700 py-8" style="transition-delay: 180ms;">
        <div class="md:col-span-3 flex flex-col gap-2">
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">N° 04</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Avid</span>
        </div>
        <div class="md:col-span-9">
          <h3 class="font-display font-light text-fluid-xl text-ink-50 leading-tight">Gaming</h3>
          <p class="mt-2 max-w-readable text-fluid-base text-ink-200 leading-relaxed">
            I play everything — competitive, weird-and-obscure, and the long-haul story stuff in between. The best games teach you something about constraints. The great ones teach you something about yourself.
          </p>
        </div>
      </li>
      <li class="reveal grid grid-cols-1 md:grid-cols-12 gap-y-3 md:gap-x-10 border-t border-b border-ink-700 py-8" style="transition-delay: 240ms;">
        <div class="md:col-span-3 flex flex-col gap-2">
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">N° 05</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">Pickleball · Tennis · Baseball</span>
        </div>
        <div class="md:col-span-9">
          <h3 class="font-display font-light text-fluid-xl text-ink-50 leading-tight">Racquet & ball</h3>
          <p class="mt-2 max-w-readable text-fluid-base text-ink-200 leading-relaxed">
            Three sports, three angles on the same puzzle: get the ball where the opponent isn't. Pickleball is the current obsession; baseball will always be the first language. Reps are reps.
          </p>
        </div>
      </li>
    </ul>
  </section>

  <!-- CURRENTLY -->
  <section class="py-20 md:py-28 border-t border-ink-700">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-4">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">04 — Currently</p>
        <h2 class="reveal mt-4 font-display font-light text-fluid-2xl tracking-tightest text-ink-50">
          What I'm <span class="italic">on</span> right now.
        </h2>
      </div>
      <ul class="md:col-span-8 flex flex-col gap-8">
        <li class="reveal grid grid-cols-12 gap-4 items-baseline border-t border-ink-700 pt-6">
          <span class="col-span-12 sm:col-span-3 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">
            JUN 2025 → NOW
          </span>
          <p class="col-span-12 sm:col-span-9 text-fluid-base text-ink-100 leading-relaxed">
            Leading the AI Analyst function at <span class="text-ink-50">Worlds</span>, running the entire production and pilot AI portfolio from a forward-deployed seat.
          </p>
        </li>
        <li class="reveal grid grid-cols-12 gap-4 items-baseline border-t border-ink-700 pt-6" style="transition-delay: 80ms;">
          <span class="col-span-12 sm:col-span-3 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">
            JAN 2026 → IMMINENT
          </span>
          <p class="col-span-12 sm:col-span-9 text-fluid-base text-ink-100 leading-relaxed">
            Shipping <span class="text-ink-50">Chirp</span>, my camp-safety platform, to the iOS and Android stores.
          </p>
        </li>
        <li class="reveal grid grid-cols-12 gap-4 items-baseline border-t border-ink-700 pt-6" style="transition-delay: 160ms;">
          <span class="col-span-12 sm:col-span-3 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300">
            ONGOING
          </span>
          <p class="col-span-12 sm:col-span-9 text-fluid-base text-ink-100 leading-relaxed">
            Building agentic systems for my own ops — <span class="text-ink-50">Switchboard</span> and <span class="text-ink-50">Mechanic</span> — and applying every lesson back into client work.
          </p>
        </li>
      </ul>
    </div>
  </section>

  <!-- ETHOS PULL-QUOTE -->
  <section class="py-28 md:py-40 border-t border-ink-700">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <div class="md:col-span-3">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">— Ethos</p>
      </div>
      <blockquote class="md:col-span-9">
        <p class="reveal font-display font-light text-fluid-display text-ink-50 leading-[0.95] tracking-tightest">
          Build&nbsp;it.<br />
          <span class="italic">Fix&nbsp;it.</span><br />
          Solve&nbsp;it.<span class="text-accent">_</span>
        </p>
        <footer class="reveal mt-8 font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-300" style="transition-delay: 120ms;">
          — The whole job description, in any room I walk into.
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- REACH OUT -->
  <section class="py-24 md:py-32 border-t border-ink-700">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-7">
        <p class="reveal font-mono text-mono-xs uppercase tracking-[0.18em] text-accent">05 — Reach out</p>
        <h2 class="reveal mt-4 font-display font-light text-fluid-3xl tracking-tightest text-ink-50 leading-[0.95]">
          Have something hard <span class="italic">to ship?</span>
        </h2>
        <p class="reveal mt-6 max-w-readable text-fluid-lg text-ink-100 leading-relaxed">
          I'm looking for generative-AI roles where the job is to build things and solve real problems. Contract or full-time. Talk to me.
        </p>
      </div>
      <div class="md:col-span-5 flex flex-col gap-5 md:pt-6">
        <a class="reveal link group flex items-baseline justify-between gap-4 border-t border-ink-700 pt-5" href="mailto:austin@austincopps.com">
          <span class="font-display font-light text-fluid-lg text-ink-50">austin@austincopps.com</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400 group-hover:text-accent transition-colors">email</span>
        </a>
        <a class="reveal link group flex items-baseline justify-between gap-4 border-t border-ink-700 pt-5" href="tel:+14696629792" style="transition-delay: 80ms;">
          <span class="font-display font-light text-fluid-lg text-ink-50">(469) 662-9792</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400 group-hover:text-accent transition-colors">phone</span>
        </a>
        <a class="reveal link group flex items-baseline justify-between gap-4 border-t border-ink-700 pt-5" href="https://linkedin.com/in/austin-copps-06332621b" target="_blank" rel="noopener" style="transition-delay: 160ms;">
          <span class="font-display font-light text-fluid-lg text-ink-50">/in/austin-copps</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400 group-hover:text-accent transition-colors">linkedin</span>
        </a>
        <a class="reveal link group flex items-baseline justify-between gap-4 border-t border-ink-700 pt-5" href="https://github.com/austincopps" target="_blank" rel="noopener" style="transition-delay: 240ms;">
          <span class="font-display font-light text-fluid-lg text-ink-50">@austincopps</span>
          <span class="font-mono text-mono-xs uppercase tracking-[0.18em] text-ink-400 group-hover:text-accent transition-colors">github</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .portrait-img {
    filter: saturate(0.92) contrast(1.02);
    transition: filter 600ms ease;
  }
  .portrait-img:hover {
    filter: saturate(1) contrast(1.04);
  }
</style>
